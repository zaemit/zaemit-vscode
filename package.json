{
  "name": "zaemit-visual-editor",
  "displayName": "Zaemit Visual Editor",
  "description": "Visual HTML/CSS editor for VS Code - edit web pages visually with drag & drop, style editing, and live preview",
  "version": "0.0.13",
  "publisher": "zaemit",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://zaemit.github.io/zaemit-vscode/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaemit/zaemit-vscode"
  },
  "bugs": {
    "url": "https://github.com/zaemit/zaemit-vscode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icons/zaemit-logo-128.png",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "html",
    "css",
    "visual editor",
    "wysiwyg",
    "drag and drop",
    "web design",
    "live preview",
    "figma",
    "figma to html"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zaemit.showMainMenu",
        "title": "Zaemit: Open Menu",
        "icon": {
          "light": "media/icons/zaemit-icon-light.svg",
          "dark": "media/icons/zaemit-icon-dark.svg"
        }
      },
      {
        "command": "zaemit.openWithEditor",
        "title": "Zaemit: Open with Visual Editor",
        "icon": {
          "light": "media/icons/zaemit-icon-light.svg",
          "dark": "media/icons/zaemit-icon-dark.svg"
        }
      },
      {
        "command": "zaemit.openCurrentFile",
        "title": "Zaemit: Open Current File in Visual Editor",
        "icon": {
          "light": "media/icons/zaemit-icon-light.svg",
          "dark": "media/icons/zaemit-icon-dark.svg"
        }
      },
      {
        "command": "zaemit.figmaImport",
        "title": "Zaemit: Import from Figma",
        "icon": "$(cloud-download)"
      },
      {
        "command": "zaemit.figmaSetToken",
        "title": "Zaemit: Set Figma Token",
        "icon": "$(key)"
      },
      {
        "command": "zaemit.figmaRemoveToken",
        "title": "Zaemit: Remove Figma Token"
      },
      {
        "command": "zaemit.showShortcuts",
        "title": "Zaemit: Show Keyboard Shortcuts"
      },
      {
        "command": "zaemit.openDocs",
        "title": "Zaemit: Open Documentation"
      },
      {
        "command": "zaemit.responsiveOptimize",
        "title": "Zaemit: AI Responsive Optimization",
        "icon": "$(device-mobile)"
      }
    ],
    "keybindings": [
      {
        "command": "zaemit.showMainMenu",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z"
      },
      {
        "command": "zaemit.openCurrentFile",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "resourceExtname == .html"
      },
      {
        "command": "zaemit.figmaImport",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "zaemit.openWithEditor",
          "when": "resourceExtname == .html",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "zaemit.showMainMenu",
          "group": "navigation",
          "when": "resourceExtname == .html"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zaemit",
          "title": "Zaemit",
          "icon": "media/icons/zaemit-icon-dark.svg"
        }
      ]
    },
    "views": {
      "zaemit": [
        {
          "id": "zaemit.menu",
          "name": "Menu",
          "type": "webview"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "zaemit.visualEditor",
        "displayName": "Zaemit Visual Editor",
        "selector": [
          {
            "filenamePattern": "*.html"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "sync": "node scripts/sync-modules.mjs",
    "build": "npm run sync && node esbuild.config.mjs",
    "dev": "npm run sync && node esbuild.config.mjs --watch",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vscode/extension-telemetry": "^0.9.8",
    "zod": "^3.25.76"
  },
  "telemetry": {
    "enabledByDefault": true,
    "respectsBuiltInTelemetrySetting": true
  }
}
